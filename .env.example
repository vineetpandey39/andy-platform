# ── ANDY Platform Environment Variables ──────────────────────────────────────

# Core AI (required)
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Codeword (change this to your actual codeword hash — currently plaintext for dev)
ANDY_CODEWORD=andy activate

# Agent: TITAN (PostForge AI)
POSTFORGE_URL=https://postforge-ai-one.vercel.app

# Agent: ALFA (YouTube)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Agent: BETA (Fiverr)
FIVERR_API_KEY=

# Agent: HERMES (Amazon KDP)
KDP_EMAIL=
KDP_PASSWORD=

# Revenue / Finance (POSEIDON)
PAYONEER_KEY=
BANK_ACCOUNT=
AUTO_TRANSFER_AMOUNT=5000

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
